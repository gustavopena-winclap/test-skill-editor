# Copy to .env and fill in. Never commit the real .env.

# GitHub fine-grained PAT with Contents: Read & Write on the target repo.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Repo that holds the marketplace (plugins/.../skills/...).
GITHUB_OWNER=Winclap
GITHUB_REPO=demo-skill-share

# Branch to read/write.
GITHUB_BRANCH=main

# Port for the local server.
PORT=3000
